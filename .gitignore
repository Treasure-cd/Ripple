# Root .gitignore — common ignores for the whole project

# Node
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.cjs
.pnp.js

# pnpm
.pnpm-store/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Build outputs
dist/
build/
public/build/
.next/
.nuxt/
out/
coverage/

# Vite / bundler cache
.vite/
node_modules/.vite/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# Databases
*.sqlite3
*.sqlite
*.db

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.sublime-*

# Misc
.cache/
/.env
